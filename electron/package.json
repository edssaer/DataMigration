{
  "name": "data-migration-tool",
  "version": "1.0.0",
  "description": "数据库迁移工具桌面应用",
  "main": "main.js",
  "author": "DataMigration",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.data-migration.tool",
    "productName": "数据库迁移工具",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "app",
        "filter": [
          "app.py",
          "templates/**/*",
          "app/**/*",
          ".env",
          "index.html"
        ]
      },
      {
        "from": "../dist/",
        "to": "app",
        "filter": [
          "data_migration_server.exe"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.6.0"
  }
}